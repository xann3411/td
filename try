-- AUTO SKILLS LOOP
task.spawn(function()
	while true do
		task.wait(0.2)

		if autoSkills then
			pressKey(Enum.KeyCode.One)
			task.wait(0.15)

			pressKey(Enum.KeyCode.Two)
			task.wait(0.15)

			pressKey(Enum.KeyCode.Three)
			task.wait(0.15)

			pressKey(Enum.KeyCode.Four)
			task.wait(0.15)

			pressKey(Enum.KeyCode.Five)
		end
	end
end)

-- AUTO REPLAY LOOP
task.spawn(function()
	while true do
		task.wait(1)

		if autoReplay then
			for _, gui in pairs(playerGui:GetDescendants()) do
				if gui:IsA("TextButton") or gui:IsA("ImageButton") then
					local nameLower = string.lower(gui.Name)
					local textLower = ""

					pcall(function()
						textLower = string.lower(gui.Text)
					end)

					if string.find(nameLower, "replay") or string.find(textLower, "replay") then
						if gui.Visible then
							gui:Activate()
						end
					end
				end
			end
		end
	end
end)
