-- Auto Upgrade: loops all placed units and upgrades each one
local function StartAutoUpgrade()
if Loops.auto_upgrade then return end
Loops.auto_upgrade = true
task.spawn(function()
while Settings.auto_upgrade do
local ok, placed = pcall(GetPlacedUnits)
if ok and placed then
for guid, unitData in pairs(placed) do
if Settings.auto_upgrade then
-- Check if unit still has upgrades available
local unitId = tostring(unitData.Type)
local upgradeLevel = 0
local maxUpgrades = 0
if unitData.Info and unitData.Info[unitId] then
upgradeLevel = unitData.Info[unitId].Upgrade or 0
if unitData.Info[unitId].Data and unitData.Info[unitId].Data.upgrades then
maxUpgrades = #unitData.Info[unitId].Data.upgrades
end
end
if upgradeLevel < maxUpgrades then
pcall(UpgradeUnit, guid)
task.wait(Settings.upgrade_delay)
end
end
end
end
task.wait(1)
end
Loops.auto_upgrade = false
end)
end

-- Auto Place: reads equipped units from inventory and places them on map spots
-- Uses InventoryId as equipString, and finds open placement spots on the map
local function StartAutoPlace()
if Loops.auto_place then return end
Loops.auto_place = true
task.spawn(function()
while Settings.auto_place do
-- Get currently placed units to avoid re-placing
local ok, placed = pcall(GetPlacedUnits)
local placedCount = 0
if ok and placed then
for _ in pairs(placed) do placedCount = placedCount + 1 end
end

-- Get placement spots from workspace
local spots = GetPlacementSpots()

-- Get player's equipped inventory units via character/player data
-- We use GetPlacedUnits data to know unit IDs already placed
-- For placing new units, the user must have units in their equipped slots
-- We attempt to place using known equipped unit data from existing placed units
if ok and placed then
local spotIndex = placedCount + 1
for guid, unitData in pairs(placed) do
-- Re-place logic: if a unit somehow isn't on map, fire PlaceUnit
-- In APD, maxPlacements defines how many of a unit you can place
local inventoryId = unitData.InventoryId
local unitType = unitData.Type
if inventoryId and unitType and spots[spotIndex] then
pcall(PlaceUnit, unitType, spots[spotIndex], inventoryId)
spotIndex = spotIndex + 1
task.wait(Settings.place_delay)
end
end
end
task.wait(3)
end
Loops.auto_place = false
end)
end

-- Auto Sell: sells all placed units once
local function SellAllUnits()
task.spawn(function()
local ok, placed = pcall(GetPlacedUnits)
if ok and placed then
for guid, _ in pairs(placed) do
pcall(SellUnit, guid)
task.wait(0.3)
end
return true
end
return false
end)
end

