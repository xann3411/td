-- Returns table keyed by GUID:
-- [guid] = {
-- Type = unitId (number),
-- Index = guid (string),
-- UnitModelName = guid (string),
-- InventoryId = "unitId#uuid" (string), <-- use as equipString for PlaceUnit
-- UnitInventoryData = { id, exp, level, trait, ... },
-- Info = { ["unitId"] = { Upgrade = n, Data = { upgrades = [...] } } }
-- }
local function GetPlacedUnits()
return GetPlacedUnitsRF:InvokeServer()
end

-- Place a unit on the map
-- unitId: number (e.g. 92)
-- cf: CFrame
-- equipString: "unitId#uuid" from InventoryId
local function PlaceUnit(unitId, cf, equipString)
GameEvent:FireServer("PlaceUnit", unitId, cf, equipString)
end

-- Upgrade a placed unit by its GUID
local function UpgradeUnit(guid)
GameEvent:FireServer("UpgradeUnit", guid)
end

-- Sell a placed unit by its GUID
local function SellUnit(guid)
SellUnitRF:InvokeServer(guid)
end

-- Vote to skip the current wave
local function VoteSkipWave()
VoteSkipWaveRF:InvokeServer()
end

-- Set game speed (1 = normal, 1.5 = fast, 2 = max)
local function SetGamespeed(speed)
SetGamespeedRF:InvokeServer(speed)
end

-- Replay / retry the game
local function Replay()
GameEvent:FireServer("Retry")
end

-- Get valid placement CFrames from workspace (hill + ground spots)
-- Returns a list of CFrames for all placeable spots on the map
local function GetPlacementSpots()
local spots = {}
for _, v in pairs(workspace:GetDescendants()) do
if v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("SpecialMesh") then
local name = v.Name:lower()
if name:find("hill") or name:find("ground") or name:find("spot")
or name:find("place") or name:find("slot") or name:find("pad")
or name:find("tower") or name:find("platform") then
table.insert(spots, v.CFrame)
end
end
end
return spots
end

